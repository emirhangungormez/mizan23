  "private": true,
  "scripts": {
    "dev": "concurrently -n \"next,engine,ready\" -c \"cyan,green,yellow\" \"npm run dev:frontend\" \"npm run dev:engine\" \"npm run dev:open\"",
    "dev:frontend": "next dev -H 0.0.0.0 -p 3000",
    "dev:engine": "cd engine-python && .venv\\Scripts\\python -m uvicorn app:app --host 0.0.0.0 --port 3003",
    "dev:open": "wait-on http-get://localhost:3000 http-get://127.0.0.1:3003/api/health && start \"\" http://localhost:3000",
    "build": "next build",
    "start": "next start -H 0.0.0.0 -p 3000",
    "lint": "eslint",
    "engine": "npm run dev:engine",
    "check:system": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\tools\\verify-system.ps1"
  },
