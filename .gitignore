/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.err.log
*.out.log
*.pid
*.seed
*.stackdump
engine.log
.engine-*.log
.next-dev*.log
.next-frontend.log
.codex-*.log

# local tooling
.agent/
.run/
.setup/
.vscode/
.codex-*.json
.codex-bist-all.json
Skor

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# python
**/__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/
.env
.pytest_cache/
.coverage
htmlcov/
*.db
*.db-shm
*.db-wal
*.log
engine-python/.venv/
engine-python/storage/**/*.json
engine-python/storage/**/*.db
engine-python/storage/**/*.db-shm
